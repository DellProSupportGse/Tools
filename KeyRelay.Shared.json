{
    "_Tool Box": [
    {
      "Name": "BOILER",
      "Command": "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12;Invoke-Expression(\u0027$module=\"BOILER\";$repo=\"PowershellScripts\"\u0027+(new-object net.webclient).DownloadString(\u0027https://raw.githubusercontent.com/DellProSupportGse/Tools/main/BOILER.ps1\u0027));Invoke-BOILER",
      "Description": "Finds Windows Update Error in CBS Logs."
    }
  ],
  "Windows OS": [
    {
      "Name": "OS Version",
      "Command": "systeminfo | findstr /B /C:\"OS Name\" /C:\"OS Version\"",
      "Description": "Displays the Windows Server OS version."
    },
    {
      "Name": "Installed Updates",
      "Command": "Get-HotFix | Sort InstalledOn -Descending",
      "Description": "Lists installed Windows updates."
    },
    {
      "Name": "Reboot Pending Check",
      "Command": "Get-ItemProperty HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Component Based Servicing\\RebootPending",
      "Description": "Checks if Windows has a pending reboot."
    }
  ],

  "Failover Clustering": [
    {
      "Name": "Cluster Nodes",
      "Command": "Get-ClusterNode",
      "Description": "Displays all nodes in the cluster."
    },
    {
      "Name": "Cluster Resources",
      "Command": "Get-ClusterResource",
      "Description": "Lists all cluster resources."
    },
    {
      "Name": "Cluster Groups",
      "Command": "Get-ClusterGroup",
      "Description": "Displays cluster roles and ownership."
    },
    {
      "Name": "Cluster Networks",
      "Command": "Get-ClusterNetwork",
      "Description": "Displays cluster network configuration."
    },
    {
      "Name": "Cluster Validation",
      "Command": "Test-Cluster",
      "Description": "Runs full cluster validation tests."
    }
  ],

  "Hyper-V": [
    {
      "Name": "List VMs",
      "Command": "Get-VM",
      "Description": "Lists all Hyper-V virtual machines."
    },
    {
      "Name": "VM Status",
      "Command": "Get-VM | Select Name, State, CPUUsage, MemoryAssigned",
      "Description": "Shows VM health and usage."
    },
    {
      "Name": "VM Network Adapters",
      "Command": "Get-VMNetworkAdapter",
      "Description": "Displays VM network adapter configuration."
    },
    {
      "Name": "Virtual Switches",
      "Command": "Get-VMSwitch",
      "Description": "Lists Hyper-V virtual switches."
    }
  ],

  "Azure Local": [
    {
      "Name": "Solution Version",
      "Command": "Get-SolutionUpdateEnvironment",
      "Description": "Displays Azure Local Solution version."
    },
    {
      "Name": "SBE Updates",
      "Command": "Get-SolutionUpdate | Where-Object{$_.packagetype -eq 'SBE'}",
      "Description": "Displays Azure Local Solution Builder Extention Updates."
    },    
    {
      "Name": "Solution Updates",
      "Command": "Get-SolutionUpdate",
      "Description": "Displays Azure Local Solution Updates."
    },    
    {
      "Name": "Azure Stack HCI Registration",
      "Command": "Get-AzureStackHCI",
      "Description": "Shows Azure Local registration status."
    },
    {
      "Name": "Action Plan Instances",
      "Command": "Get-ActionPlanInstances | Select-Object Action*Name,InstanceId , Status,*Date*| Sort-Object EndDateTime | Format-Table",
      "Description": "Shows Action Plan Instances Information."
    }
  ],
"Arc Agent": [
    {
      "Name": "Arc Show",
      "Command": "& 'C:\\Program Files\\AzureConnectedMachineAgent\\azcmagent.exe' show",
      "Description": "Displays Arc Agent Version Information."
    },
  {
      "Name": "Arc Check",
      "Command": "& 'C:\\Program Files\\AzureConnectedMachineAgent\\azcmagent.exe' check",
      "Description": "Displays Arc Agent Connectivity/Gateway Information."
    }
  ],
  "Network ATC": [
    {
      "Name": "ATC Intents",
      "Command": "Get-NetIntent",
      "Description": "Lists configured Network ATC intents."
    },
    {
      "Name": "Intent Status",
      "Command": "Get-NetIntentStatus",
      "Description": "Displays status of Network ATC configuration."
    },
    {
      "Name": "Global ATC Settings",
      "Command": "Get-NetIntentStatus -GlobalOverride",
      "Description": "Displays global ATC overrides."
    }
  ],
"Search": [
  {
    "Name": "Last xMins Logs",
    "Command": "$xMins=15; Get-ChildItem C:\\ -Recurse -File -ErrorAction SilentlyContinue | Where-Object { $_.LastWriteTime -ge (Get-Date).AddMinutes(-$xMins) -and $_.Extension -match '\\.(log|txt|out|err|trace)$' } | Sort-Object LastWriteTime -Descending | Select-Object FullName, LastWriteTime, Length | Format-Table -AutoSize",
    "Description": "Find all logs that changed in the last X minutes"
  }
],
  "Storage Spaces Direct": [
    {
      "Name": "Smb Multi Channel (SBL)",
      "Command": "Get-SmbMultichannelConnection -SmbInstance SBL",
      "Description": "Lists S2D Storage Bus Links (SBL)."
    },    
    {
      "Name": "Storage Pools",
      "Command": "Get-StoragePool -IsPrimordial $False",
      "Description": "Lists S2D storage pools."
    },
    {
      "Name": "Physical Disks",
      "Command": "Get-PhysicalDisk | sort deviceid",
      "Description": "Displays physical disks used by Storage Spaces."
    },
    {
      "Name": "Virtual Disks",
      "Command": "Get-VirtualDisk",
      "Description": "Lists S2D virtual disks."
    },
    {
      "Name": "Storage Jobs",
      "Command": "Get-StorageJob",
      "Description": "Displays active storage repair jobs."
    }
  ],

  "Networking": [
    {
      "Name": "IP Configuration",
      "Command": "ipconfig /all",
      "Description": "Displays detailed network adapter configuration."
    },
    {
      "Name": "Routing Table",
      "Command": "route print",
      "Description": "Displays the system routing table."
    },
    {
      "Name": "Network Adapters",
      "Command": "Get-NetAdapter | select Name, InterfaceDescription, ifIndex, Status, MacAddress, LinkSpeed, DriverVersion | ft",
      "Description": "Lists all network adapters with driver version."
    },
    {
      "Name": "NIC Advanced Settings",
      "Command": "Get-NetAdapterAdvancedProperty",
      "Description": "Displays advanced NIC settings."
    },
    {
      "Name": "RDMA Enabled",
      "Command": "Get-NetAdapterRdma | sort Enabled",
      "Description": "Displays RDMA Status."
    },
    {
      "Name": "QOS Information",
      "Command": "Get-NetAdapterQos | sort Enabled",
      "Description": "Displays RDMA Status."
    }
  ],

  "Troubleshooting": [
    {
      "Name": "Event Log Errors",
      "Command": "Get-EventLog -LogName System -EntryType Error -Newest 20",
      "Description": "Shows the most recent system errors."
    },
    {
      "Name": "Cluster Log",
      "Command": "Get-ClusterLog -UseLocalTime",
      "Description": "Generates cluster diagnostic logs."
    },
    {
      "Name": "Top Processes",
      "Command": "Get-Process | Sort CPU -Descending | Select -First 10",
      "Description": "Displays top CPU consuming processes."
    }
  ]
}
